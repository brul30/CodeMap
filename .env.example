# ─────────────────────────────────────────────────────────────
# CodeMap env reference. Copy the relevant section into:
#   web/.env.local   (Next.js)      worker/.env   (standalone worker)
# NEXT_PUBLIC_* = exposed to the browser. Everything else = server/worker only.
# NEVER put service-role / secret keys in NEXT_PUBLIC_* or the client bundle.
# ─────────────────────────────────────────────────────────────

# ===== GEMINI (you already have this) — web server + worker =====
# AI Studio → Get API key.  One key covers 3.5 Flash, 3.1 Flash TTS, Managed Agents, Live API.
GEMINI_API_KEY=

# ===== CLERK (auth) — web =====
# Clerk dashboard → API keys.  Dev instance uses SHARED GitHub OAuth creds = zero config,
# BUT you must still enable: Social Connections → GitHub → On.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# optional UX redirects
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ===== SUPABASE (db + storage + realtime) — client, web server, worker =====
# Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # client-side realtime subscription (needs RLS read policy)
SUPABASE_SERVICE_ROLE_KEY=              # web server + worker ONLY — privileged writes/storage. NEVER client.

# ===== PINECONE (RAG vectors) — web server + worker =====
# Pinecone console → API Keys.  Create a serverless index first (note its name).
PINECONE_API_KEY=
PINECONE_INDEX=codemap                  # the serverless index name

# ===== WORKER wiring =====
# Default design = worker POLLS Supabase for queued projects → no URL needed.
# Only set this if you go push-based (web calls the worker over HTTP).
# WORKER_URL=https://<your-worker>.up.railway.app
