# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key

# Supabase
# NOTE: Supabase renamed its keys. New key system → our env var:
#   Publishable key (sb_publishable_...) → NEXT_PUBLIC_SUPABASE_ANON_KEY  (browser-safe)
#   Secret key      (sb_secret_...)      → SUPABASE_SERVICE_ROLE_KEY       (server/worker ONLY)
# Get both from: Dashboard → Project Settings → API Keys.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_secret_key

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key

# Pinecone
PINECONE_API_KEY=your_pinecone_api_key
