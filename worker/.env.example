# =============================================================================
# .env.example — CodeMap Worker
#
# Copy this file to .env and fill in every value before running the worker.
# Never commit .env — it is in .gitignore.
# Run  npm run check-env  to verify all keys are set.
# =============================================================================

# Gemini API key (Google AI Studio → "Get API key")
GEMINI_API_KEY=

# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=

# Supabase service-role secret key (Settings → API → service_role)
# IMPORTANT: This has full DB access — never expose it client-side.
SUPABASE_SERVICE_ROLE_KEY=

# Pinecone API key (Pinecone Console → API Keys)
PINECONE_API_KEY=

# Pinecone index name to use (created by  npm run create-index)
# Default assumed by the create-index script: codemap
PINECONE_INDEX=codemap
